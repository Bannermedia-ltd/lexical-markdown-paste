{
  "name": "@scrivenmark/lexical-markdown-paste",
  "version": "0.1.0",
  "description": "Paste markdown as rich text in Lexical editors with heuristic detection",
  "license": "MIT",
  "author": "Lettergraph <hello@lettergraph.co>",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bannermedia-ltd/lexical-markdown-paste.git"
  },
  "bugs": {
    "url": "https://github.com/Bannermedia-ltd/lexical-markdown-paste/issues"
  },
  "homepage": "https://github.com/Bannermedia-ltd/lexical-markdown-paste#readme",
  "keywords": [
    "lexical",
    "markdown",
    "paste",
    "clipboard",
    "rich-text",
    "editor",
    "plugin"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lexical/markdown": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "lexical": "^0.40.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@lexical/code": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/markdown": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^25.0.0",
    "lexical": "^0.40.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
